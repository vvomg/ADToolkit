global
    log /dev/log    local0
    log /dev/log    local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    maxconn {{ maxconn | default(50000) }}
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-ciphersuites TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets

defaults
    log     global
    option  dontlognull
    timeout connect  5s
    timeout client   60s
    timeout server   60s

listen stats
    bind *:1936
    mode http
    stats enable
    stats uri /stats
    stats realm IVA\ Mail\ HAProxy\ Stats
    stats auth admin:{{ stats_password | default('admin') }}
    stats refresh 5s
    stats show-legends
    stats show-node

# ── HTTP ──────────────────────────────────────────────────────────────

frontend fe_http
    bind *:80
    mode http
    option httplog
    option forwardfor
    option http-server-close
    timeout client 60s
    default_backend be_http

backend be_http
    mode http
    balance roundrobin
    option forwardfor
    option http-server-close
    option httpchk GET /
    http-check expect status 200-499
    timeout connect 5s
    timeout server  60s
{% for fe in frontend_servers %}
    server fe-{{ fe.ip | replace('.', '-') }} {{ fe.ip }}:80 check inter 10s fall 3 rise 2
{% endfor %}

# ── HTTPS ─────────────────────────────────────────────────────────────

frontend fe_https
    bind *:443
    mode tcp
    option tcplog
    timeout client 300s
    default_backend be_https

backend be_https
    mode tcp
    balance roundrobin
    timeout connect 5s
    timeout server  300s
{% for fe in frontend_servers %}
