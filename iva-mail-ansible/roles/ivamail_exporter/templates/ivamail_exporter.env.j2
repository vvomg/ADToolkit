# Env-файл для ivamail-exporter — сгенерировано Ansible, не редактировать вручную
IVAMAIL_HOSTS={{ ivamail_exporter_hosts | regex_replace(',+', ',') | regex_replace('^,|,$', '') }}
IVAMAIL_CMD_USER={{ ivamail_cmd_user }}
IVAMAIL_CMD_PASSWORD={{ ivamail_cmd_password }}
IVAMAIL_CMD_PORT={{ ivamail_cmd_port }}
EXPORTER_PORT={{ ivamail_exporter_port }}
SCRAPE_TIMEOUT={{ ivamail_scrape_timeout }}
